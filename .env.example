# Copy this file to .env and fill in your values
# cp .env.example .env

# ── AI Backend ────────────────────────────────────────────────────────────────
# OpenAI API key (used by both Codex CLI and the openai Python SDK fallback)
OPENAI_API_KEY=sk-...

# AI model to use for algorithm generation
# Recommended: o3 (best reasoning for C++ algo design), gpt-4o (faster)
OPENAI_MODEL=o3

# ── Path Configuration ────────────────────────────────────────────────────────
# Absolute WSL path to the Google XLS source clone
# Windows: d:\final\xls  →  WSL: /mnt/d/final/xls
XLS_SRC_PATH=/mnt/d/final/xls

# Absolute WSL path to the pre-built XLS binary release (for bootstrapping)
# Windows: d:\final\xls-v0.0.0-...  →  WSL: /mnt/d/final/xls-v0.0.0-...-linux-x64
XLS_BIN_PATH=/mnt/d/final/xls-v0.0.0-9840-gd53059466-linux-x64

# ── Build Configuration ───────────────────────────────────────────────────────
# Bazel target for the codegen tool
CODEGEN_BAZEL_TARGET=//xls/tools:codegen_main

# Number of parallel Bazel jobs (set to your CPU core count)
BAZEL_JOBS=8
